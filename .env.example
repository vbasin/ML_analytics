# ── Databento ──────────────────────────────────────────────
DATABENTO_API_KEY=your-databento-api-key-here

# ── PostgreSQL / TimescaleDB ──────────────────────────────
PGUSER=
PGPASSWORD=changeme
PGHOST=localhost
PGPORT=5432
PGDATABASE=

# ── Application ───────────────────────────────────────────
VTECH_DATA_DIR=
VTECH_LOG_LEVEL=INFO
VTECH_FEATURES_TIMESTEP=5s
VTECH_LABEL_THRESHOLD=50
VTECH_SEQUENCE_LENGTH=128
VTECH_FORWARD_WINDOWS=60,120,180,360
VTECH_TRADING_HOURS_START=08:00
VTECH_TRADING_HOURS_END=11:00
VTECH_TIMEZONE=America/Chicago
